# ─── Required ─────────────────────────────────────────────────────────────────

# MongoDB connection string (from MongoDB Atlas or any MongoDB provider)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

# Secret used to sign JWT tokens — use a long random string in production
JWT_SECRET=change_me_to_a_long_random_secret

# ─── Optional ─────────────────────────────────────────────────────────────────

# Port the server listens on (hosting platforms auto-set this)
PORT=3000

# URL of your deployed frontend (e.g. https://your-site.netlify.app)
# Set to * to allow all origins (not recommended for production)
FRONTEND_URL=*

# Admin credentials seeded on first startup
ADMIN_EMAIL=mehedihasan123456789.mh.mh@gmail.com
ADMIN_PASSWORD=111111
